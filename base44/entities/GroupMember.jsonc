{
  "name": "GroupMember",
  "type": "object",
  "properties": {
    "group_id": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "member",
        "admin"
      ],
      "default": "member"
    }
  },
  "required": [
    "group_id",
    "user_email"
  ]
}