{
  "name": "User",
  "type": "object",
  "properties": {
    "facebook_page_id": {
      "type": "string",
      "description": "Connected Facebook Page ID for live streaming"
    },
    "facebook_page_name": {
      "type": "string",
      "description": "Facebook Page name"
    },
    "facebook_live_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether Facebook Live is connected"
    }
  }
}