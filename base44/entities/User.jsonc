{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "account_type": {
      "type": "string",
      "enum": [
        "customer",
        "business_owner"
      ],
      "default": "customer",
      "description": "User account type"
    },
    "username": {
      "type": "string",
      "description": "Unique username \u2014 set once at signup"
    },
    "username_set": {
      "type": "boolean",
      "default": false,
      "description": "Whether the user has set their username"
    },
    "is_seller": {
      "type": "boolean",
      "default": false
    },
    "seller_location": {
      "type": "string"
    },
    "seller_area": {
      "type": "string"
    },
    "seller_bio": {
      "type": "string",
      "description": "Short seller/business bio"
    },
    "seller_page_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether seller has activated their public seller page"
    },
    "is_verified_seller": {
      "type": "boolean",
      "default": false,
      "description": "Admin grants blue checkmark after full document verification"
    },
    "verification_submitted": {
      "type": "boolean",
      "default": false,
      "description": "Seller has submitted documents for verification"
    },
    "member_type": {
      "type": "string",
      "enum": [
        "buyer",
        "seller",
        "both"
      ],
      "default": "buyer"
    },
    "location": {
      "type": "string",
      "description": "User's primary location"
    },
    "notifications_enabled": {
      "type": "boolean",
      "default": true
    },
    "email_updates": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "role"
  ]
}